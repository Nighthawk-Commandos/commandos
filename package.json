{
  "name": "commandos-mainframe",
  "version": "1.0.0",
  "private": true,
  "description": "Nighthawk Commandos Mainframe — TNI:C division management system",
  "scripts": {
    "dev": "npm run build && netlify dev",
    "build": "esbuild js/app.js --bundle --minify --format=esm --platform=browser --outfile=dist/app.min.js",
    "watch": "esbuild js/app.js --bundle --format=esm --platform=browser --outfile=dist/app.min.js --watch"
  },
  "dependencies": {
    "@netlify/blobs": "^7.3.0",
    "firebase": "^12.12.0",
    "firebase-admin": "^12.0.0",
    "netlify": "^24.9.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
